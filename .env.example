# Gowa-Bot Configuration Example

# Owner numbers (comma separated, use international format without +)
# Example: 6281234567890,6289876543210
export GOWA_BOT_OWNERS="62xxx"

# Database path (optional, default: gowa-bot.db)
# export GOWA_BOT_DB="/path/to/database.db"

# Log level (optional, default: info)
# Options: debug, info, warn, error
# export GOWA_BOT_LOG_LEVEL="debug"
